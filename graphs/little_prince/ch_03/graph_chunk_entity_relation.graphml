    </node>
    <node id="Художник">
      <data key="d0">Художник</data>
      <data key="d1">person</data>
      <data key="d2">Childhood aspiration of the narrator, a profession that he gave up after failing at drawing an inside-out snake and being ridiculed by adults. Original name: художник.</data>
      <data key="d3">doc-4bbba4040fb365b4890e658b464d7d8e-chunk-000</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782404249</data>
