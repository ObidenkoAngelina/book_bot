    </node>
    <node id="Джунгли">
      <data key="d0">Джунгли</data>
      <data key="d1">location</data>
      <data key="d2">Vast tropical rainforest where the story takes place, specifically referring to the dense jungle with mythological creatures like the giant snake. Original name: джунгли.</data>
      <data key="d3">doc-4bbba4040fb365b4890e658b464d7d8e-chunk-000</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782404249</data>
