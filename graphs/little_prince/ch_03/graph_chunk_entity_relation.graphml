    </node>
    <node id="Летчик">
      <data key="d0">Летчик</data>
      <data key="d1">person</data>
      <data key="d2">Another career chosen after abandoning childhood aspirations to become an artist. Original name: летчик.</data>
      <data key="d3">doc-4bbba4040fb365b4890e658b464d7d8e-chunk-000</data>
      <data key="d4">unknown_source</data>
