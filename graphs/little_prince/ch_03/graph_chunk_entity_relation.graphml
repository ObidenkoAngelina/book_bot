  <graph edgedefault="undirected">
    <node id="Удав">
      <data key="d0">Удав</data>
      <data key="d1">creature</data>
      <data key="d2">Mythical snake that swallowed an elephant in the illustration and was compared to a hat by adults. Original name: удав, which is a type of large Asian snake.</data>
      <data key="d3">doc-4bbba4040fb365b4890e658b464d7d8e-chunk-000</data>
      <data key="d4">unknown_source</data>
