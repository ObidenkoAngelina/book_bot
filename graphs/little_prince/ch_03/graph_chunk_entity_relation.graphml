    </node>
    <node id="Учитель">
      <data key="d0">Учитель</data>
      <data key="d1">person</data>
      <data key="d2">Adult who advised the narrator not to draw outside of his understanding and expertise, especially about animals and geography. Original name: учитель.</data>
      <data key="d3">doc-4bbba4040fb365b4890e658b464d7d8e-chunk-000</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782404249</data>
