      <data key="d3">doc-a4e544d8de8adf2c2d92737023d20063-chunk-000</data>
      <data key="d2">The relation name "Очень скоро я лучше узнал этот цветок, неведомая гостья" describes a character who is both beautiful and elegant. She looks at a small sprout without diverting her eyes, waits for the moment when the petals will open, invites Little Prince to go with her, gets offended that she is not grass, gets ready to present herself in a pleasing manner, reminds the Little Prince about having breakfast, and mentions a threat posed by tigers.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
