    <edge source="Content" target="Семена баобаба">
      <data key="d7">1.0</data>
      <data key="d8">}</data>
      <data key="d9">Invisible seeds that grow into baobab trees. They are hidden underground and can only sprout when one decides to do so.</data>
      <data key="d10">doc-1b8b1d20aa2c3a367e6898ef909e1830-chunk-001</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1782466820</data>
      <data key="d13" />
    </edge>
    <edge source="NaturalObject" target="Баобаб">
      <data key="d7">1.0</data>
      <data key="d8">}</data>
      <data key="d9">A large tree native to tropical regions,known for its ability to grow massive roots that can take over a planet.</data>
      <data key="d10">doc-1b8b1d20aa2c3a367e6898ef909e1830-chunk-001</data>
      <data key="d11">unknown_source</data>
